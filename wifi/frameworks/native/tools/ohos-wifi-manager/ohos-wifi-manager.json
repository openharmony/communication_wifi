{
    "name": "ohos-wifiManager",
    "version": "1.0.0",
    "description": "WiFi STA mode control tool for enabling/disabling STA mode and scanning networks",
    "executablePath": "/system/bin/cli_tool/executable/ohos-wifiManager",
    "requirePermissions": [],
    "hasSubCommand": true,
    "inputSchema": {
      "type": "object",
      "properties": {}
    },
    "outputSchema": {
      "type": "object",
      "properties": {}
    },
    "subcommands": {
      "sta-enable": {
        "description": "Enable WiFi STA mode",
        "requirePermissions": [
          "ohos.permission.SET_WIFI_INFO",
          "ohos.permission.MANAGE_WIFI_CONNECTION"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": {
              "type": "boolean"
            },
            "message": {
              "type": "string"
            }
          }
        }
      },
      "sta-disable": {
        "description": "Disable WiFi STA mode",
        "requirePermissions": [
          "ohos.permission.SET_WIFI_INFO",
          "ohos.permission.MANAGE_WIFI_CONNECTION"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": {
              "type": "boolean"
            },
            "message": {
              "type": "string"
            }
          }
        }
      },
      "scan-start": {
        "description": "Start WiFi scan",
        "requirePermissions": [
          "ohos.permission.SET_WIFI_INFO"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": {
              "type": "boolean"
            },
            "message": {
              "type": "string"
            }
          }
        }
      },
      "scan-list": {
        "description": "List WiFi scan results",
        "requirePermissions": [
          "ohos.permission.GET_WIFI_INFO",
          "ohos.permission.GET_WIFI_PEERS_MAC"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "success": {
              "type": "boolean"
            },
            "networks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "ssid": {
                    "type": "string"
                  },
                  "bssid": {
                    "type": "string"
                  },
                  "securityType": {
                    "type": "number"
                  },
                  "rssi": {
                    "type": "number"
                  },
                  "frequency": {
                    "type": "number"
                  }
                }
              }
            },
            "count": {
              "type": "number"
            }
          }
        }
      }
    },
    "eventTypes": [],
    "eventSchemas": {}
  }