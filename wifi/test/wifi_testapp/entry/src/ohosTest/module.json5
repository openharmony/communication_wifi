{
    "module": {
        "name": "entry_test",
        "type": "feature",
        "description": "$string:module_test_desc",
        "mainElement": "TestAbility",
        "deviceTypes": [
            "default",
            "tablet"
        ],
        "deliveryWithInstall": true,
        "installationFree": false,
        "pages": "$profile:test_pages",
        "abilities": [
            {
                "name": "TestAbility",
                "srcEntry": "./ets/TestAbility/TestAbility.ets",
                "description": "$string:TestAbility_desc",
                "icon": "$media:icon",
                "label": "$string:TestAbility_label",
                "visible": true,
                "startWindowIcon": "$media:icon",
                "startWindowBackground": "$color:start_window_background",
                "skills": [
                    {
                        "actions": [
                            "action.system.home"
                        ],
                        "entities": [
                            "entity.system.home"
                        ]
                    }
                ]
            }
        ],
        "requestPermissions": [
            {
                "name": "ohos.permission.SET_WIFI_INFO",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.SET_WIFI_CONFIG",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.GET_WIFI_CONFIG",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.GET_WIFI_LOCAL_MAC",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.GET_WIFI_INFO",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.GET_WIFI_PEERS_MAC",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.MANAGE_WIFI_CONNECTION",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.MANAGE_ENTERPRISE_WIFI_CONNECTION",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.MANAGE_WIFI_HOTSPOT",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.GET_NETWORK_INFO",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.LOCATION",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "always"
                }
            },
            {
                "name": "ohos.permission.APPROXIMATELY_LOCATION",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "always"
                }
            },
            {
                "name": "ohos.permission.LOCATION_IN_BACKGROUND",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "always"
                }
            },
            {
                "name": "ohos.permission.DISTRIBUTED_DATASYNC",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ]
                }
            },
            {
                "name": "ohos.permission.INTERNET",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            },
            {
                "name": "ohos.permission.KEEP_BACKGROUND_RUNNING",
                "reason": "$string:TestAbility_desc",
                "usedScene": {
                    "abilities": [
                        "TestAbility"
                    ],
                    "when": "inuse"
                }
            }
        ]
    }
}
